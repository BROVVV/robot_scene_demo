SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen3-VL-8B-Instruct
SILICONFLOW_TIMEOUT_SECONDS=25
SILICONFLOW_MAX_TOKENS=2048
IMAGE_MAX_SIDE=1280
IMAGE_DETAIL=high
ENABLE_LOW_OBJECT_RETRY=true
MIN_OBJECTS_FOR_COMPLEX_SCENE=6
ENABLE_IMAGE_PREPROCESS=true
IMAGE_PREPROCESS_SHARPEN=false
IMAGE_PREPROCESS_DENOISE=false
ENABLE_TILED_DETECTION=false
TILE_SIZE=960
TILE_OVERLAP=160
ENABLE_TARGET_PROFILE=true
TARGET_PROFILE_LANGUAGE=zh_en
TARGET_PROFILE_MAX_TERMS=40
ENABLE_TARGET_SYNONYM_EXPANSION=true
ENABLE_CONTEXT_OBJECT_EXPANSION=true
OUTPUT_DIR=outputs

DETECTION_BACKEND=llm
GROUNDED_SAM_ROOT=/home/user/python3.10.0/Grounded-SAM-2
GROUNDED_SAM_PYTHON=/home/user/python3.10/bin/python
GROUNDED_SAM_PYTHONPATH=/home/user/python3.10/lib/python3.10/site-packages
GROUNDING_DINO_CONFIG=grounding_dino/groundingdino/config/GroundingDINO_SwinT_OGC.py
GROUNDING_DINO_CHECKPOINT=gdino_checkpoints/groundingdino_swint_ogc.pth
GROUNDING_DINO_BOX_THRESHOLD=0.12
GROUNDING_DINO_TEXT_THRESHOLD=0.10
GROUNDING_DINO_HIGH_RECALL_BOX_THRESHOLD=0.10
GROUNDING_DINO_HIGH_RECALL_TEXT_THRESHOLD=0.08
ENABLE_GDINO_HIGH_RECALL=true
ENABLE_SAM2=true
ENABLE_SAM2_MASK_FEATURES=true
SAM2_CONFIG=configs/sam2.1/sam2.1_hiera_t.yaml
SAM2_CHECKPOINT=checkpoints/sam2.1_hiera_tiny.pt
MAX_DETECTED_OBJECTS=100
DETECTION_DEVICE=auto
DETECTOR_TIMEOUT_SECONDS=60

# Candidate crop verification and score fusion
ENABLE_CROP_VERIFY=true
CROP_VERIFY_BACKEND=llm
CROP_VERIFY_MAX_CANDIDATES=40
CROP_VERIFY_EXPAND_RATIO=1.35
CROP_VERIFY_MIN_SCORE=0.55
CROP_VERIFY_TARGET_SCORE=0.70
CROP_VERIFY_TIMEOUT_SECONDS=60
CROP_VERIFY_SAVE_CROPS=true
CROP_VERIFY_OUTPUT_DIR=outputs/crops
ENABLE_SCORE_FUSION=true
FUSION_WEIGHT_DETECTOR=0.30
FUSION_WEIGHT_VLM=0.45
FUSION_WEIGHT_ATTRIBUTE=0.15
FUSION_WEIGHT_CONTEXT=0.10
FINAL_TARGET_SCORE_THRESHOLD=0.65
FINAL_CANDIDATE_SCORE_THRESHOLD=0.45

# Video detection and temporal voting
VIDEO_SAMPLE_FPS=3.0
VIDEO_MAX_FRAMES=300
VIDEO_ENABLE_TRACKING=true
VIDEO_TRACK_IOU_THRESHOLD=0.35
VIDEO_TRACK_MAX_MISSING_FRAMES=8
VIDEO_TRACK_MIN_HITS=2
VIDEO_TARGET_CONFIRM_MIN_FRAMES=3
VIDEO_TARGET_CONFIRM_SCORE=0.65
VIDEO_ENABLE_TRACK_LEVEL_VOTING=true
VIDEO_VERIFY_EVERY_N_FRAMES=2
VIDEO_SAVE_CANDIDATE_CROPS=true

# Evaluation
EVAL_IOU_THRESHOLD=0.5
EVAL_OUTPUT_DIR=outputs/eval

# Video scene memory and PSG reasoning
VIDEO_ENABLE_SCENE_MEMORY=true
VIDEO_ALWAYS_WRITE_MEMORY=true
VIDEO_ENABLE_VIDEO_PSG=true
VIDEO_ENABLE_NEGATIVE_EVIDENCE=true
VIDEO_ENABLE_REASONING_REPORT=true
VIDEO_MEMORY_STORE_PATH=data/memory/video_spatial_memory.jsonl
VIDEO_MIN_MEMORY_IMPORTANCE=low
VIDEO_LLM_FRAME_INTERVAL_SEC=2.0
VIDEO_PSG_SUMMARY_INTERVAL_SEC=5.0
VIDEO_MAX_MEMORY_ENTRIES_PER_VIDEO=200
VIDEO_MEMORY_DEDUP_SIMILARITY=0.86
VIDEO_ENABLE_MEMORY_RETRIEVAL=true
VIDEO_MEMORY_RETRIEVAL_TOP_K=10
VIDEO_SCENE_REASONER_BACKEND=llm
VIDEO_FORCE_JSON_OUTPUT=true

# LLM-first situated search reasoning for quadruped robots
ENABLE_LLM_SITUATED_REASONING=true
ENABLE_LLM_REASONING_MEMORY=true
LLM_REASONING_MAX_HYPOTHESES=5
LLM_REASONING_TIMEOUT_SECONDS=40
LLM_REASONING_TEMPERATURE=0.2
LLM_REASONING_REQUIRE_ACTIONABILITY_GATE=true
LLM_REASONING_REQUIRE_VISUAL_GATE=true
QUADRUPED_MAX_FORWARD_STEP_M=0.5
QUADRUPED_CAN_MANIPULATE=false
QUADRUPED_CAN_OPEN_CONTAINER=false
QUADRUPED_CAN_LOOK_DOWN=false
LLM_EXPERIENCE_MEMORY_PATH=data/memory/llm_spatial_experience.jsonl
ENABLE_LLM_DYNAMIC_VISUAL_RETRY=true
LLM_DYNAMIC_VISUAL_RETRY_MAX_TERMS=12

# Platform-assisted adaptive motion horizon.
# Obstacle avoidance is assumed to be handled by the robot platform/SDK/ROS safety layer.
PLATFORM_OBSTACLE_AVOIDANCE_ASSUMED=true
ENABLE_DYNAMIC_MOTION_HORIZON=true
MOTION_HORIZON_PROFILE=platform_assisted_auto
MOTION_STRICT_SAFE_MAX_STEP_M=0.5
MOTION_PLATFORM_INDOOR_DEFAULT_STEP_M=1.2
MOTION_PLATFORM_INDOOR_MAX_STEP_M=2.0
MOTION_PLATFORM_OPEN_DEFAULT_STEP_M=3.0
MOTION_PLATFORM_OPEN_MAX_STEP_M=5.0
MOTION_ABSOLUTE_MAX_STEP_M=6.0
MOTION_TARGET_CONFIRM_MAX_STEP_M=0.8
MOTION_PLATFORM_FALLBACK_STEP_M=1.5
MOTION_DEFAULT_STOP_AND_REOBSERVE=true
MOTION_ENABLE_OBSERVE_WHILE_MOVING=false
MOTION_SOFT_OBSERVE_INTERVAL_SEC=1.0
MOTION_SHORTEN_ON_TARGET_CANDIDATE=true
MOTION_ALLOW_LLM_RECOMMENDED_HORIZON=true
MOTION_LLM_HORIZON_WEIGHT=0.6

# ================================
# Handcrafted prior control
# ================================
STATIC_KNOWLEDGE_BASE_ENABLED=false
HANDWRITTEN_OBJECT_PRIORS_ENABLED=false
HANDWRITTEN_LOCATION_PRIORS_ENABLED=false
HANDWRITTEN_ROOM_PRIORS_ENABLED=false
STATIC_OBJECT_PROMPTS_ENABLED=false
ALLOW_HANDCRAFTED_SEARCH_RULES=false

# ================================
# LLM-generated runtime commonsense prior
# ================================
LLM_COMMONSENSE_PRIOR_ENABLED=true
LLM_PRIOR_GENERATION_MODE=runtime
LLM_PRIOR_REQUIRE_REASON=true
LLM_PRIOR_ALLOW_SEARCH_HINTS=true
LLM_PRIOR_ALLOW_DETECTOR_PROMPTS=true
LLM_PRIOR_CAN_CONFIRM_TARGET=false
LLM_PRIOR_MAX_HYPOTHESES=8
LLM_PRIOR_MAX_DETECTOR_PROMPTS=12
LLM_PRIOR_OUTPUT_LANGUAGE=zh

# ================================
# Evidence gating
# ================================
EVIDENCE_GATING_ENABLED=true
TARGET_CONFIRMATION_REQUIRE_VISUAL_EVIDENCE=true
TARGET_CONFIRMATION_REQUIRE_BBOX=true
TARGET_CONFIRMATION_REQUIRE_CROP_VERIFY=true
TARGET_CONFIRMATION_REQUIRE_MASK=false
TARGET_CONFIRMATION_MIN_SCORE=0.72
TARGET_INFERRED_IS_NOT_FOUND=true

# ================================
# Observation memory
# ================================
OBSERVATION_MEMORY_ENABLED=true
OBSERVATION_MEMORY_STORE_PATH=data/memory/observational_memory.jsonl
OBSERVATION_MEMORY_WRITE_VISUAL_ONLY=true
OBSERVATION_MEMORY_ALLOW_LLM_SUMMARY=true
OBSERVATION_MEMORY_LLM_SUMMARY_AS_HYPOTHESIS=true
OBSERVATION_MEMORY_RETRIEVAL_TOP_K=10
OBSERVATION_MEMORY_REQUIRE_PROVENANCE=true

# ================================
# Prior usage audit
# ================================
PRIOR_USAGE_AUDIT_ENABLED=true
PRIOR_USAGE_REPORT_PATH=outputs/prior_usage_report.json
